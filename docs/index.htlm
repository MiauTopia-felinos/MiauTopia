<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MiauTopia — Sistema de Gestão</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--P:#c2607e;--Pl:#fdf0f4;--Pm:#f5c8d8;--V:#7dbf9e;--Vl:#eef7f2;--A:#f0c860;--Al:#fdf8e8;--C:#6b6570;--Cl:#f7f5f8;--Cb:#e8e4ec;--T:#2d2830;--Tm:#8a8090;--W:#fff;--F:#faf8fb}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--F);color:var(--T);font-size:13.5px}
.app{display:flex;min-height:100vh}
.sb{width:210px;background:var(--W);border-right:1px solid var(--Cb);position:fixed;top:0;left:0;bottom:0;z-index:100;overflow-y:auto;display:flex;flex-direction:column}
.logo{padding:15px 14px;border-bottom:1px solid var(--Cb)}
.logo-n{font-size:17px;font-weight:700;color:var(--P)}.logo-s{font-size:10px;color:var(--Tm);text-transform:uppercase;letter-spacing:.05em}
.ns{padding:7px 13px 3px;font-size:9.5px;font-weight:700;color:var(--Tm);text-transform:uppercase;letter-spacing:.08em}
.ni{display:flex;align-items:center;gap:8px;padding:7px 15px;cursor:pointer;color:var(--C);font-size:12px;border:none;background:none;width:100%;text-align:left;transition:all .15s;border-left:2px solid transparent}
.ni:hover{background:var(--Cl);color:var(--T)}.ni.on{background:var(--Pl);color:var(--P);font-weight:600;border-left-color:var(--P)}
.main{margin-left:210px;flex:1;display:flex;flex-direction:column}
.tb{background:var(--W);border-bottom:1px solid var(--Cb);padding:0 22px;height:50px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50}
.pt{font-size:14px;font-weight:600}.ct{padding:18px 22px}
.card{background:var(--W);border:1px solid var(--Cb);border-radius:10px;padding:15px 19px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:11px}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:11px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:9px}
.met{background:var(--W);border:1px solid var(--Cb);border-radius:9px;padding:12px 14px}
.ml{font-size:10px;color:var(--Tm);text-transform:uppercase;letter-spacing:.04em;margin-bottom:3px}
.mv{font-size:19px;font-weight:700}.ms{font-size:11px;color:var(--Tm);margin-top:2px}
.fg{margin-bottom:11px}
.fl{display:block;font-size:11px;font-weight:600;color:var(--C);margin-bottom:3px}
.fc{width:100%;padding:7px 10px;border:1px solid var(--Cb);border-radius:7px;font-size:13px;color:var(--T);background:var(--W);outline:none;font-family:inherit;transition:border-color .15s}
.fc:focus{border-color:var(--P)}.fc.ok{border-color:var(--V);background:var(--Vl)}.fc.err{border-color:#dc2626;background:#fff5f5}
textarea.fc{resize:vertical}
.btn{padding:6px 13px;border-radius:7px;font-size:12px;font-weight:500;cursor:pointer;border:none;transition:all .15s;display:inline-flex;align-items:center;gap:5px;font-family:inherit;white-space:nowrap}
.bp{background:var(--P);color:#fff}.bs{background:var(--Cl);color:var(--T);border:1px solid var(--Cb)}.bd{background:#fee2e2;color:#b91c1c}.bv{background:var(--Vl);color:#2d7a54}.ba{background:#eef3fe;color:#4f8ef7}
.sm2{padding:4px 8px;font-size:11px}
.tw{overflow-x:auto}.tw table{width:100%;border-collapse:collapse;min-width:500px}
th{font-size:10px;font-weight:700;color:var(--Tm);text-transform:uppercase;padding:7px 10px;border-bottom:1px solid var(--Cb);text-align:left;white-space:nowrap}
td{padding:8px 10px;border-bottom:1px solid var(--Cb);font-size:12.5px;vertical-align:middle}
tr:last-child td{border-bottom:none}tr:hover td{background:var(--Cl)}
.bdg{display:inline-flex;align-items:center;padding:2px 7px;border-radius:20px;font-size:10.5px;font-weight:500}
.bR{background:var(--Al);color:#92680a}.bCI{background:var(--Vl);color:#2d7a54}.bCO{background:#fee2e2;color:#b91c1c}.bCAN{background:var(--Cl);color:var(--C)}.bFIN{background:#ede9fe;color:#5b21b6}
.mo{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.4);display:flex;align-items:center;justify-content:center;padding:14px;overflow-y:auto}
.md{background:var(--W);border-radius:12px;padding:22px;width:660px;max-width:100%;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.2)}
.mdL{width:820px}.mdXL{width:960px}
.mtt{font-size:16px;font-weight:700;margin-bottom:16px}
.mft{display:flex;gap:8px;justify-content:flex-end;margin-top:16px;padding-top:13px;border-top:1px solid var(--Cb)}
.tabs{display:flex;border-bottom:1px solid var(--Cb);margin-bottom:14px;flex-wrap:wrap}
.tab{padding:7px 13px;cursor:pointer;font-size:12.5px;border:none;background:none;color:var(--Tm);border-bottom:2px solid transparent;margin-bottom:-1px;font-family:inherit;transition:all .15s}
.tab.on{color:var(--P);border-bottom-color:var(--P);font-weight:500}
.emp{text-align:center;padding:32px;color:var(--Tm)}
.fb{display:flex;justify-content:space-between;align-items:center}
.fx{display:flex}.g8{gap:8px}.g16{gap:16px}
.mt8{margin-top:8px}.mt12{margin-top:12px}.mt16{margin-top:16px}
.mb8{margin-bottom:8px}.mb12{margin-bottom:12px}.mb16{margin-bottom:16px}
.mu{color:var(--Tm)}.sm{font-size:11.5px}
.sec{font-size:11px;font-weight:700;color:var(--P);margin:13px 0 8px;padding-bottom:4px;border-bottom:1px solid var(--Pm)}
.pgb{height:5px;background:var(--Cb);border-radius:3px;overflow:hidden}.pgf{height:100%;background:var(--V);border-radius:3px;transition:width .3s}
.ps{display:inline-flex;align-items:center;padding:2px 7px;border-radius:12px;font-size:10.5px;font-weight:500}
.pQ{background:var(--Vl);color:#2d7a54}.pP{background:var(--Al);color:#92680a}.pN{background:#fee2e2;color:#b91c1c}
.ar{display:flex;gap:3px;flex-wrap:nowrap}
.cg{display:grid;grid-template-columns:90px repeat(31,minmax(19px,1fr));gap:1px;background:var(--Cb);border-radius:8px;overflow:hidden;font-size:10px}
.ch{background:var(--Cl);padding:4px 2px;text-align:center;font-weight:600;color:var(--Tm);font-size:9px}
.cb2{background:var(--W);padding:4px 7px;font-weight:500;font-size:10px}.cbt{font-size:8px;color:var(--Tm)}
.cc2{background:var(--W);min-height:24px;display:flex;align-items:center;justify-content:center;padding:1px}
.cch{border-radius:2px;padding:1px 2px;font-size:8px;font-weight:500;width:100%;text-align:center;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.cOC{background:var(--Pl);color:var(--P)}.cCI{background:var(--Vl);color:#2d7a54}.cCO{background:#fee2e2;color:#b91c1c}
.cHJ{background:var(--P);color:#fff;font-weight:700}.cAL{background:var(--Al)}
.rtag{background:var(--Vl);color:#2d7a54;border-radius:4px;padding:1px 6px;font-size:11px;font-weight:500}
.dtag{background:#fee2e2;color:#b91c1c;border-radius:4px;padding:1px 6px;font-size:11px;font-weight:500}
.dr{display:flex;justify-content:space-between;padding:6px 0;font-size:12.5px;border-bottom:1px solid var(--Cb)}
.dr.tot{font-weight:700;font-size:14px;border-bottom:2px solid var(--P);color:var(--P)}
.dr.sub{padding-left:14px;color:var(--Tm);font-size:12px}
.dr.sec2{font-weight:600;background:var(--Cl);padding:5px 8px;border-radius:5px;margin-top:6px;border-bottom:none}
.nf-doc{border:2px solid var(--Cb);border-radius:8px;padding:20px;font-size:12px;line-height:1.6}
.nf-sec{border:1px solid var(--Cb);border-radius:6px;padding:10px 13px;margin-bottom:9px}
.nf-t{font-size:10px;font-weight:700;color:var(--Tm);text-transform:uppercase;margin-bottom:7px}
.nf-g{display:grid;grid-template-columns:1fr 1fr;gap:7px}
.nf-i{display:flex;flex-direction:column;gap:1px}
.nf-l{font-size:10px;color:var(--Tm)}.nf-v{font-size:12.5px;font-weight:500}
.eb{height:6px;background:var(--Cb);border-radius:3px;margin-top:4px}.ef{height:100%;border-radius:3px}
.pop-card{border:1px solid var(--Cb);border-radius:8px;padding:12px 14px;margin-bottom:9px}
.pop-cat{display:inline-block;padding:2px 8px;border-radius:12px;font-size:11px;font-weight:500;background:var(--Vl);color:#2d7a54;margin-bottom:7px}
.pop-step{display:flex;gap:9px;padding:5px 0;border-bottom:1px solid var(--Cb);font-size:12.5px;align-items:flex-start}
.pop-num{width:20px;height:20px;border-radius:50%;background:var(--P);color:#fff;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0;margin-top:1px}
.ag-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:1px;background:var(--Cb);border-radius:8px;overflow:hidden}
.ag-h{background:var(--Cl);padding:6px 4px;text-align:center;font-size:11px;font-weight:600;color:var(--Tm)}
.ag-d{background:var(--W);min-height:70px;padding:4px;cursor:pointer}
.ag-d:hover{background:var(--Pl)}.ag-d.hj{background:var(--Pl)}
.ag-dn{font-size:12px;font-weight:600;color:var(--Tm);margin-bottom:2px}
.ag-d.hj .ag-dn{color:var(--P);font-weight:700}.ag-d.om .ag-dn{color:var(--Cb)}
.ag-ev{border-radius:3px;padding:1px 4px;font-size:10px;margin-bottom:1px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.evR{background:var(--Al);color:#92680a}.evC{background:#eef3fe;color:#4f8ef7}
.tp{border:1px solid var(--Cb);border-radius:8px;padding:11px 14px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center}
.tA{border-left:3px solid var(--A)}.tB{border-left:3px solid var(--V)}
.pend-card{border:1px solid var(--Cb);border-left:4px solid var(--A);border-radius:8px;padding:12px 14px;margin-bottom:9px}
.cb-item{display:flex;align-items:center;gap:7px;padding:5px 9px;background:var(--Cl);border-radius:6px;cursor:pointer;font-size:12px;margin-bottom:5px}
.step-bar{display:flex;justify-content:center;gap:4px;margin-bottom:14px}
.step{width:28px;height:5px;border-radius:3px;background:var(--Cb)}
.step.on{background:var(--P)}.step.dn{background:var(--V)}
.fstep{display:none}.fstep.on{display:block}
@media print{.sb,.tb,.no-print{display:none!important}.main{margin-left:0}body{background:#fff}}
</style>
</head>
<body>
<div class="app">
<aside class="sb" id="sidebar">
  <div class="logo">
    <div class="logo-n" id="logo-n">🐱 MiauTopia</div>
    <div class="logo-s" id="logo-s">Hotel Felino</div>
  </div>
  <nav>
    <div class="ns">Principal</div>
    <button class="ni on" onclick="go('dash')">🏠 Dashboard</button>
    <button class="ni" onclick="go('reservas')">📋 Reservas</button>
    <button class="ni" onclick="go('cal')">📅 Calendário</button>
    <button class="ni" onclick="go('agenda')">🗓️ Agenda</button>
    <div class="ns">Financeiro</div>
    <button class="ni" onclick="go('fin')">💰 Recebimentos</button>
    <button class="ni" onclick="go('lanc')">📒 Lançamentos</button>
    <button class="ni" onclick="go('dre')">📊 DRE</button>
    <button class="ni" onclick="go('nf')">🧾 Espelho NF</button>
    <div class="ns">Operação</div>
    <button class="ni" onclick="go('orc')">💼 Orçamento</button>
    <button class="ni" onclick="go('rel')">📝 Relatórios</button>
    <button class="ni" onclick="go('pops')">📌 POPs</button>
    <div class="ns">Cadastros</div>
    <button class="ni" onclick="go('tutores')">👥 Tutores e Gatos</button>
    <button class="ni" onclick="go('autocad')">🔗 Autocadastro</button>
    <button class="ni" onclick="go('pendentes')">⏳ Pendentes <span id="badge-pend" style="background:var(--A);color:#92680a;border-radius:10px;padding:1px 6px;font-size:10px;font-weight:600;margin-left:auto;display:none">0</span></button>
    <button class="ni" onclick="go('servicos')">🛎️ Serviços</button>
    <button class="ni" onclick="go('produtos')">🛍️ Produtos</button>
    <button class="ni" onclick="go('insumos')">📦 Insumos</button>
    <button class="ni" onclick="go('temps')">🌡️ Temporadas</button>
    <button class="ni" onclick="go('contratos')">📄 Contratos</button>
    <div class="ns">Config</div>
    <button class="ni" onclick="go('empresa')">🏢 Empresa</button>
    <button class="ni" onclick="go('pers')">🎨 Personalização</button>
  </nav>
</aside>
<main class="main">
  <div class="tb"><div class="pt" id="ptitle">Dashboard</div><div class="fx g8" id="pact"></div></div>
  <div class="ct" id="pc"></div>
</main>
</div>
<div id="modal"></div>
<script>
